        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "title": "All Logs",
      "type": "logs",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${DS_LOKI}"
          },
          "expr": "{container=~\"$container\"} |~ `(?i)(\"level\":\"|level=)($level)`",
          "legendFormat": "",
          "refId": "A",
          "maxLines": 1000
        }
      ]
    }
  ]
}