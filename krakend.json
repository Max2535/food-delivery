{
  "version": 3,
  "port": 8080,
  "timeout": "3s",
  "extra_config": {
    "telemetry/metrics": {
      "collection_time": "30s",
      "proxy_disabled": false,
      "router_disabled": false,
      "backend_disabled": false,
      "endpoint_disabled": false,
      "listen_address": ":9091"
    },
    "telemetry/logging": {
      "level": "DEBUG",
      "prefix": "[KRAKEND]",
      "syslog": false,
      "stdout": true
    }
  },
  "endpoints": [
    {
      "endpoint": "/v1/orders",
      "method": "POST",
      "extra_config": {
        "auth/validator": {
          "alg": "RS256",
          "jwk_local_path": "/etc/krakend/public_key.json",
          "jwk_url": "http://localhost:8080",
          "roles": ["user", "admin"],
          "disable_jwk_security": true,
          "propagate_claims": [
            ["user_id", "X-User-Id"],
            ["roles", "X-User-Roles"]
          ]
        }
      },
      "backend": [
        {
          "url_pattern": "/api/v1/orders",
          "host": ["http://order-service-api:3000"]
        }
      ]
    },
    {
      "endpoint": "/v1/kitchen/status/{id}",
      "method": "GET",
      "backend": [
        {
          "url_pattern": "/api/v1/kitchen/orders/{id}",
          "host": ["http://kitchen-service-api:3001"]
        }
      ]
    },
    {
      "endpoint": "/v1/catalog/menus",
      "method": "GET",
      "backend": [
        {
          "url_pattern": "/api/v1/catalog/menus",
          "host": ["http://catalog-service-api:3003"]
        }
      ]
    },
    {
