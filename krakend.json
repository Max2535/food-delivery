{
  "version": 3,
  "port": 8080,
  "timeout": "3s",
  "extra_config": {
    "telemetry/metrics": {
      "collection_time": "30s",
      "proxy_disabled": false,
      "router_disabled": false,
      "backend_disabled": false,
      "endpoint_disabled": false,
      "listen_address": ":9091"
    }
  },
  "endpoints": [
    {
      "endpoint": "/v1/orders",
      "method": "POST",
      "backend": [
        {
          "url_pattern": "/api/v1/orders",
          "host": ["http://order-service-api:3000"]
        }
      ]
    },
    {
      "endpoint": "/v1/kitchen/status/{id}",
      "method": "GET",
      "backend": [
        {
          "url_pattern": "/api/v1/kitchen/orders/{id}",
          "host": ["http://kitchen-service-api:3001"]
        }
      ]
    },
    {
      "endpoint": "/v1/auth/login",
      "method": "POST",
      "backend": [
        {
          "url_pattern": "/api/v1/auth/login",
          "host": ["http://auth-service:3002"]
        }
      ]
    },
    {
      "endpoint": "/v1/auth/register",
      "method": "POST",
      "backend": [
        {
          "url_pattern": "/api/v1/auth/register",
          "host": ["http://auth-service:3002"]
        }
      ]
    }
  ]
}
